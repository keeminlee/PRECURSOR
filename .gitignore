# Precursor .gitignore

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
!.vscode/settings.json
.idea/

# Runtime / generated
docs/
PLANS/
PROJECTS.md

# Demo plan trees are part of the package, not user-generated work
!demo-interactive/PLANS/
!demo-interactive/PLANS/**

# Node (if any project uses it)
node_modules/

# Python (if any project uses it)
__pycache__/
*.pyc
.venv/
